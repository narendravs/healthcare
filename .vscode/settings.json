{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "always"
  },
  "editor.tabSize": 2,

  /* 1. TypeScript & IntelliSense Optimization */
  "typescript.tsdk": "./node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,
  "typescript.suggestionActions.enabled": true,
  "editor.suggestSelection": "recentlyUsed",
  /* This tells VS Code specifically to check this path for TS */
  "javascript.suggest.enabled": true,
  "typescript.format.enable": true,

  /* 2. Tailwind CSS v4 Specifics */
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "plaintext": "ts",
    "typescript": "typescript",
    "typescriptreact": "typescriptreact"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*)\"['`]"], // Helps with CVA (Class Variance Authority)
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*)\"['`]"]  // Helps with your 'cn' utility
  ],

  /* 3. Performance: Hide unnecessary noise from Suggestions */
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.turbo": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  },

  /* 4. Project-Specific Snippets & Suggestions */
  "editor.suggest.showWords": false, // Disables annoying generic word suggestions
  "editor.snippetSuggestions": "top", // Puts snippets (like 'rafce') at the very top
  "explorer.compactFolders": false
}
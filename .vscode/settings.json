{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "always"
  },
  "editor.tabSize": 2,

  /* 1. TypeScript & IntelliSense Optimization (Unified Namespace) */
  "js/ts.tsdk.path": "./node_modules/typescript/lib",
  "js/ts.tsdk.promptToUseWorkspaceVersion": true,
  "js/ts.suggest.enabled": true,

  // Prevents the language server from aggressively locking dependencies on boot
  "js/ts.preferences.includePackageJsonAutoImports": "on",

  // Allocates extra memory overhead to the unified background server loop
  "js/ts.tsserver.maxMemory": 4096,

  // ADDED: Actively blocks VS Code file-watchers from deep-crawling active framework environments
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.next/**": true,
    "**/.turbo/**": true,
    "**/dist/**": true
  },

  /* 2. Tailwind CSS v4 Specifics */
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.includeLanguages": {
    "plaintext": "ts",
    "typescript": "typescript",
    "typescriptreact": "typescriptreact"
  },
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*)\"['`]"],
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*)\"['`]"]
  ],

  /* 3. Performance: Hide unnecessary noise from Suggestions */
  "files.exclude": {
    "**/.next": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.turbo": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true
  },

  /* 4. Project-Specific Snippets & Suggestions */
  "editor.suggest.showWords": false,
  "editor.snippetSuggestions": "top",
  "explorer.compactFolders": false
}
